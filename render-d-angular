				((that.selectedCaseDecision && $scope.cisCase.frtf && 
				 that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.APPROVED) ||
				 that.adminCloseForI131HP())){

				that.config.forceSupervisorReview = false;
