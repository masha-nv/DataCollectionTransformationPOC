		if (!that.isCaseI131DACA() && that.selectedCaseDecision != null && that.selectedCaseDecision.caseDecCd === 1) {
			if (that.isCaseI131FrtfReparole() || $scope.isI131HP11() || $scope.isI131FRTFInsideUSParole()) {
				$scope.i94View = true;
			} else {
				caseTagsService.getCaseTagsData($scope.cisCase.caseId).then(function(response) {
					$scope.caseTags = response.data.reduce(function(map, obj) {
						map[obj] = true;
						return map;
					}, {});
					
					if ($scope.caseTags[PIP_ADD_FAMILY_CASE_TAG] 
						|| $scope.caseTags[PIP_PARENT_LG_CASE_TAG] 
						|| $scope.caseTags[PIP_SEP_CHILD_CASE_TAG] 
						|| $scope.caseTags[OAW_RE_PAROLE_CASE_TAG] 
						|| $scope.caseTags[UHP_REPAROLE_CASE_TAG]
						|| that.caseHasFRTFReparoleCaseTag()){
						$scope.i94View = true;
