	that.findCaseDecision = function(caseDecisionCode) {
		let dec = $scope.refData.decisionCdSubsetData[$scope.cisCase.formType]
			.find(dec => dec.caseDecCd.caseDecCd == caseDecisionCode);
		
		if (dec) {
			return dec.caseDecCd;
		}
		return null;
	}
	
	that.findDecisionReason = function(decisionReasonCode) {
		let rsn = $scope.refData.decisionReasonSubsetCodes[$scope.cisCase.formType]
			.find(rns => rns.decRsnCd == Number(decisionReasonCode));
			
		if (rsn) {
			return rsn;
		}
		return null;
	}
	
	that.findApprovalNoticeType = function(approvalNoticeType){
		let approvalNoticeTypes = CASE_REVIEW_CONFIG.approvalNoticeTypes;

		if (that.isCaseI131FrtfReparole()) {
			return getFRTFReparoleNoticeTypeOptions()[0];
		}
		
		if (that.isCaseI131DOSLES()) {
			approvalNoticeTypes = DOS_LES_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}

		if (that.isCaseI131HPOAW()) {
			approvalNoticeTypes = OAW_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}

		if (that.isCaseI131UHPReparole()) {
			approvalNoticeTypes = UHP_REPAROLE_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}

		if (that.isCaseI131F()) {
			approvalNoticeTypes = I131F_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}

		if ($scope.isI131HP11()) {
			approvalNoticeTypes = HP11_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}

		if ($scope.isI131FRTFInsideUSParole()) {
			approvalNoticeTypes = FRTF_CASE_REVIEW_CONFIG.approvalNoticeTypes;
		}
		
		for (const key in approvalNoticeTypes){
			if(approvalNoticeTypes[key].value ===  Number(approvalNoticeType)){
				return approvalNoticeTypes[key];
			}
		}
		
		return null;
	}

	that.findWithdrawnNoticeType = function(withdrawnNoticeType){
		let withdrawnNoticeTypes = CASE_REVIEW_CONFIG.withdrawnNoticeTypes;
		for (const key in withdrawnNoticeTypes){
				if(withdrawnNoticeTypes[key].value ===  Number(withdrawnNoticeType)){
					return withdrawnNoticeTypes[key];
				}
		}
		return null;
	}

	that.findHR1ConditionalApprovalNoticeType = function(decReasonCd) {
		let condApprovalHR1NoticesTypes = CASE_REVIEW_CONFIG.conditionalApprovalHR1NoticeTypes;
		for (const key in condApprovalHR1NoticesTypes) {
			if (condApprovalHR1NoticesTypes[key].value === Number(decReasonCd)) {
				return condApprovalHR1NoticesTypes[key];
			}
		}
		return null;
	}
	
	that.displayI94 = function(){
