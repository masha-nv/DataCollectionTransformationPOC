	// Checks if the parole period (currently only for I-131 DACA) is within the allowed amount of days (364 days or less)
	// and is not beyond an already existing DACA end date
	that.isParolePeriodValid = function() {
		if (that.isI131DACAApprovalDecisionMade() && that.paroleValidTo !== null && that.paroleValidFrom !== null) {
			var daysApart = (that.paroleValidTo.getTime() - that.paroleValidFrom.getTime()) / (1000 * 3600 * 24);
			if (that.dacaEndDate !== null) {
				if (that.paroleValidFrom >= that.dacaEndDate) {
					that.parolePeriodErrorMessage = "\"Parole Valid From\" date must not exceed the applicant's current DACA end/return date."
					return false;
				}
				else if (that.paroleValidTo < that.dacaEndDate) {
					return daysApart >= 0 && daysApart <= 364;
				}
				that.parolePeriodErrorMessage = "\"Parole Valid To\" date must not exceed the applicant's current DACA end/return date."
				return false;
			}
			return daysApart >= 0 && daysApart <= 364;
		}
		return true;
	}

