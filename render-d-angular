	that.loadData = function(decision) {
		that.loadRefData();
		if (decision.renderDecision) {
			that.selectedCaseDecision = that.findCaseDecision(Number(decision.renderDecision));
			that.decisionReasonOptions = that.mapDecisionReasonOptions($scope.cisCase.formType, that.selectedCaseDecision);
			that.selectedApprovalNoticeType = that.findApprovalNoticeType(decision.approvalNoticeType);
			that.selectedWithdrawnNoticeType = that.findWithdrawnNoticeType(decision.decisionReasonCode);
			
			if(decision.renderDecision == CASE_DECISION_CODES.CONDITIONALLY_APPROVE) { // conditional approval
				that.paroleFeeExempt = false;
				that.disableParoleFeeQuestion = true;
				that.paroleValidFrom = new Date(decision.startDate);
				that.paroleValidTo = new Date(decision.endDate);
			}
			that.displayI94();
			
			if (that.displayParoleFeeQuestion) {
				aosReviewService.getUIQuestionResponse($scope.cisCase.caseId, 1356, 1188).then(function(response) {
					that.paroleFeeExempt = response.data.responseCd !== null ? response.data.responseCd === 'Y' : null;
					that.disableParoleFeeQuestion = that.paroleFeeExempt !== null;
				});
			}
		}
		if($scope.decision_.startDate && $scope.decision_.endDate){
			that.paroleValidFrom = new Date($scope.decision_.startDate);
			that.paroleValidTo = new Date($scope.decision_.endDate);
		} else if(that.isCaseI131FrtfReparole()) {
			let payload = {};
			let searchCriteria = {
				idType: "ALIEN_NUMBER",
				idValue: $scope.cisCase.benefitType === BENEFIT_TYPE_DESCRIPTIONS.OTHER_INSIDE_US_NEW_PERIOD_OF_PAROLE ? $scope.cisCase.beneficiaryAlienRegistrationNumber : $scope.cisCase.alienRegistrationNumber
			}
			payload.uscisReceiptNumber = $scope.cisCase.uscisNumber;
			payload.adjudicatorId = $scope.cisCase.adjudicatorId;
			payload.adisSearchRequest = searchCriteria;
			travelHistoryService.searchAdis(payload).then(function (response) {
				let latestArrivalWithAUD = response.data.adisResponseList.find(x => x.eventType === 'Arrival' && x.admitUntilDate != null);
				if(latestArrivalWithAUD !== undefined){
					let admitUntilDate = new Date($filter('date')(latestArrivalWithAUD.admitUntilDate.split('T')[0], 'MM-dd-yyyy'));
					that.paroleValidTo = new Date(admitUntilDate.getFullYear() + 3, admitUntilDate.getMonth(), admitUntilDate.getDate());
					admitUntilDate.setDate(admitUntilDate.getDate() + 1);
					that.paroleValidFrom = admitUntilDate;
				}
			});
		}
		that.displayParoleBackdate();
		if($scope.decision_.dob){
			$scope.formatDob = moment($scope.decision_.dob, 'MM/DD/YYYY');
			$scope.formatDob = moment($scope.formatDob).format("DD/MM/YYYY");
		}
		// Reset decision if originally conditionally approved
		if (that.isValidHR1QuestionCase() && !that.displayParoleFeeQuestion && that.selectedCaseDecision !== null && that.selectedCaseDecision.caseDecCd === 87 && !that.isSupervisoryReviewMode()) {
			that.selectedCaseDecision = null;
			that.selectedDecisionReason = null;
		} else {
			that.selectedDecisionReason = that.findDecisionReason(Number(decision.decisionReasonCode));
			that.selectedConditionalApprovalHR1NoticeType = that.findHR1ConditionalApprovalNoticeType(decision.decisionReasonCode);
		}
		if(that.isI131CAFRPConductInterview()){ //I131 CAFRP avoid preloading decision options
			that.selectedDecisionReason = null;
			that.selectedCaseDecision = null;
		} 

		that.requestedEadInitial = decision.requestedEad;
		that.requestedEadTypeInitial = decision.requestedEadType;

		that.updateSendToSupervisorReview(decision);
		getNoticeOptionValue();
		that.loadCommentsData();
		
		that.consulateOfficeOptions = that.mapConsulateOfficeOptions(that.selectedCaseDecision);
		that.approvalNoticeTypeOptions = that.mapApprovalNoticeTypeOptions();
		that.conditionalApprovalHR1NoticeTypeOptions = that.mapConditionalApprovalHR1NoticeTypeOptions();
		that.withdrawnNoticeTypeOptions = that.mapWithdrawnNoticeTypeOptions();
		that.continueNoticeTypeOptions = that.mapContinueNoticeTypeOptions();
		
		that.setupConsulateOffice(decision.consulateOffice);		

		that.setupVaccinationStatus(decision.vaccinationStatus);

		if (that.shouldForceSupervisorReview() && (that.isInitialOfficerDecisionMode() || that.isReturnedToOfficerMode())) {
			decision.sendToSupervisorReview = true;
			decision.supervisorReviewCode = 'Y';
		}
		
		that.updateForwardCaseDataList();

		if (that.isInitialOfficerDecisionMode()) {
			$scope.isEditMode = true;
		}

		that.setParoleDuration();

		that.i94Number = $scope.decision_.arrivalDepartureRecordNumber;
		that.handleMissingI94NumberMessage();

		that.getBeneficiaryCountryOfCitizenshipName()

		that.setClassOfAdmission();

		$scope.$emit('decisionLoaded', $scope.decision_);
		$scope.$emit('broadcastToAll', 'caseDecLoaded', {});
	};

	that.getCountryObj = function(country){
		that.loadRefData();
		if(country == ""){
			return;
		}
		let c4Countries = $filter('filter')($scope.refData.countryCodes, { c4CountryCode: country});
		let dosCountries = $filter('filter')($scope.refData.countryCodes, { dosCountryCode: country});
		if(c4Countries === undefined && dosCountries === undefined){
			return;
		}
		if(c4Countries.length !== 0 || dosCountries.length !== 0){
			return c4Countries.length !== 0? c4Countries[0]: dosCountries[0];
		}
	}

	that.getBeneficiaryCountryOfCitizenshipName = function(){
		if($scope.cisCase.petitionerId || $scope.cisCase.petitionerANumber){
			let coc = $scope.cisCase.beneficiaryCountryOfCitizenshipOrNationality;
			let cocObj = that.getCountryObj(coc);
			if(cocObj){
				$scope.cisCase.beneficiaryCountryOfCitizenshipOrNationalityName = cocObj.countryName.toUpperCase();
			}else {
				$scope.cisCase.beneficiaryCountryOfCitizenshipOrNationalityName = coc? coc.toUpperCase(): "";
			}
		} else {
			$scope.cisCase.beneficiaryCountryOfCitizenshipOrNationalityName = null;
		}		
	}
	
	
	
	that.handleUHPReparoleCPVTaskStatus = function(caseId) {
		CaseTasksService.getTasksByTaskTypes(caseId, [29]).then(function (response) {
			let data = response.data;
			if (Array.isArray(data) && data.length > 0) {
				if (data[0].taskStatus === 'COMPLETED') {
					that.i131UHPReparoleCPVTaskStatus = true;
				}
			}
		});
	}
	
