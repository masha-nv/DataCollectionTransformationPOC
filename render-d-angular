		$rootScope.$broadcast('dyn-tab-remove-mainMenu', $scope.cisCase.uscisNumber + ' (Rendering Decision) ');
		$rootScope.$broadcast('dyn-tab-remove-mainMenu', $scope.cisCase.uscisNumber + ' (Continue Decision) ');
		$rootScope.$broadcast('dyn-tab-remove-mainMenu', $scope.cisCase.uscisNumber + ' (Conduct Interview) ');

