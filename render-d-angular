	that.setupFinalizeDecision = function(dec) {
		if (dec) {
			$scope.decision_ = dec;
		}
		that.checkForEadOverride($scope.decision_);
		that.confirmActionModal.action = "Finalize Decision";
		that.confirmActionModal.uscisNo = $scope.decision_.uscisNo;
		that.confirmActionModal.callback = that.finalizeDecision;
	}
	
	that.finalizeDecision = function() {
		$scope.decision_.caseDecisionStatus = CASE_DECISION_STATUS.FINAL;
		$scope.decision_.isCaseDecCompleted = true;
		$scope.decision_.forFinalizeDecision = true;
		//finalizes the dec
		that.saveOrFinalizeDecision(that.finalizeAllMode ? that.completeCurrentDecision : that.completeTask);
	};

	that.setupSaveAndNext = function() {
		that.confirmActionModal.action = "Save a Draft and Continue";
		that.confirmActionModal.uscisNo = $scope.cisCase.uscisNumber;
		that.confirmActionModal.callback = that.saveDecision;
	}
	
	that.saveDecision = function() {
		$scope.decision_.caseDecisionStatus = CASE_DECISION_STATUS.PENDING;
		$scope.decision_.isCaseDecCompleted = false;
		$scope.decision_.forFinalizeDecision = false;
		that.saveOrFinalizeDecision(that.goToNextTask);
		$scope.isEditMode = false;
	};

	const RENDER_DEC_TASK_TYPES = [TASK_TYPE.CASE_REVIEW, TASK_TYPE.RENDER_DECISION,TASK_TYPE.FILING_CATEGORY_DETERMINATION];

	that.goToNextTask = function() {
		let pendingDecisions = getPendingConcurrentDecisions();
		if (pendingDecisions.length === 0) {
			that.finalizeAllMode = true;
			that.loadConcurrentCaseDecs();
		} else {
			that.goToCaseTask(pendingDecisions[0].caseId)
		}
	}

	that.goToCaseTask = function(caseId) {
		CaseTasksService.getTasksByTaskTypes(caseId, RENDER_DEC_TASK_TYPES).then(function (response) {
			let latestTask = response.data.sort((a,b) => b.taskUpdateDateTime - a.taskUpdateDateTime)[0];
			let workType = latestTask.workTypeCode === null ? that.mapWorkTypeCode(latestTask): latestTask.workTypeCode;
			that.nextNavLink ='/taskResolution/' + latestTask.receiptNumber 
				+ '/' + workType
				+ '/' + latestTask.userTaskId;
			
			$location.path(that.nextNavLink).search({
				link: "renderDecision",
				edit: 'true'});
			that.finalizeAllMode = false;
		});
	}

	that.mapWorkTypeCode = function(task) {
		switch(task.taskTypeValue){
			case TASK_TYPE.CONDUCT_INTERVIEW: {
				return WORK_TYPES.CONDUCT_INTERVIEW;
			}
			case TASK_TYPE.CASE_REVIEW: {
				return WORK_TYPES.CASE_REVIEW;
			}
			default: return WORK_TYPES.RENDER_DECISION;
		}
	}
	
	that.saveOrFinalizeDecision = function(callback) {
		that.saving = true;
		$scope.decision_.supervisorReviewCode = $scope.decision_.sendToSupervisorReview ? 'Y' : 'N';
		
		if (that.displayParoleFeeQuestion) {
			aosReviewService.saveQuestionResponse($scope.cisCase.caseId, 1356, 1188, that.paroleFeeExempt);
		}
		
		//finalize the decision here
		decisionServices.runDecisionChecks($scope.decision_).then(function(decisionStops) {
			$scope.decision_.decisionHardStops = decisionStops.data;
			if(decisionStops.data.length === 0) {
				
				if(that.paroleValidFrom && that.paroleValidTo){
					$scope.decision_.startDate = moment(that.paroleValidFrom).format("YYYY-MM-DD");
					$scope.decision_.endDate = moment(that.paroleValidTo).format("YYYY-MM-DD");
				}
				
				if($scope.cisCase.caseTypeName == 'I-131-CFRP' && !$scope.decision_.alienNumber && $scope.cisCase.alienRegistrationNumber){
					$scope.decision_.alienNumber = $scope.cisCase.alienRegistrationNumber;
				}
				
				if(that.isCaseI131HPOAW() || that.isCaseI131UHPReparole()){
					$scope.decision_.arrivalDepartureRecordNumber = that.i94Number;
					if (!that.is131ConditionallyApproved() && that.noticeOptionValue == 'select') {
						$scope.decision_.approvalNoticeType = that.selectedApprovalNoticeType.value;
						$scope.decision_.ngsDecisionReasonCode = that.selectedApprovalNoticeType.value;
					}
				}

				if(that.isCaseI131RPOrRTD() && $scope.reactDecisionData) {
					const decisionData = $scope.reactDecisionData;
					// Set Start and End Dates
					$scope.decision_.startDate = moment(decisionData.validityPeriod.startValidity).format("YYYY-MM-DD");
					$scope.decision_.endDate = moment(decisionData.validityPeriod.endValidity).format("YYYY-MM-DD");

					// Send reactDecisionData as renderDecisionQuestions object. causes error!
					// $scope.decision_.renderDecisionQuestions = $scope.reactDecisionData;

					// Set mailing address for Travel Document Production
					let mailingAddress;
					if(decisionData.mailingAddress.sendToUSAddress) {
						mailingAddress = decisionData.mailingAddress.contact.mailingAddress;
						$scope.decision_.mailingAddress = new Array(
							// Address
							mailingAddress.streetAddress1Text ?? '',
							mailingAddress.streetAddress2Text ?? '',
							mailingAddress.cityName ?? '',
							mailingAddress.stateCode ?? '',
							mailingAddress.postalZipCode ?? '',
							mailingAddress.unitTypeCode ?? '',
							mailingAddress.suiteApartmentNumber ?? '',
							'USA',
							// Contact
							decisionData.mailingAddress.contact.name ?? '',
							decisionData.mailingAddress.contact.phone ?? '',
							decisionData.mailingAddress.contact.email ?? '',
						)
					} else {
						mailingAddress = decisionData.mailingAddress.contact;
						$scope.decision_.mailingAddress = new Array(
							// Address
							mailingAddress.street ?? '',
							mailingAddress.street2 ?? '',
							mailingAddress.city ?? '',
							mailingAddress.state ?? '',
							mailingAddress.zipCode ?? '',
							mailingAddress.unitTypeCode ?? '',
							decisionData.mailingAddress.consulate ?? '',
							mailingAddress.country ?? '',
							// Contact
							mailingAddress.CO ?? '',
							mailingAddress.phone ?? '',
							mailingAddress.email ?? '',
						)
					}
					$scope.decision_.mailingAddress.push(decisionData.mailingAddress.sendToUSAddress);
					$scope.decision_.mailingAddress.push(decisionData.admittance);

					// For Testing to prevent render decision.
					// console.log($scope.decision_);
					// $scope.decision_.startDate = null;
					// $scope.decision_.endDate = null;

					// To kick off Travel Document Production
					$scope.decision_.isCaseDecCompleted = true;
					$scope.decision_.printingOption = 2;
				}
				
				decisionServices.saveOrFinalizeDecision($scope.decision_).then(function (response) {
					that.saving = false;
					let errorMessages = response.data.errorMessages;
					if (errorMessages && errorMessages.length > 0) {
						errorMessages.forEach(message => that.renderDecisionMessages.push({message: message, type: "error"}));
						return;
					}		
					$scope.$emit('decisionLoaded', response.data);
					that.addNote();
					that.renderDecisionMessages.push({message: 'Decision successfully saved.', type: "success"});
					if (callback) {
						callback();
					}

					if(that.isCaseDetailsView()) {
						$rootScope.$broadcast('broadcastToAll','dyn-tab-select-mainMenu', {action:'remove'});
					}

					if(that.isCaseI131CAFRP() && that.isConductInterview()){
						that.navigateToCaseDetails();
					}

				}, function(response) {
					that.saving = false;
					that.renderDecisionMessages.push({message: response.data.message, type: "error"});
				});
			}
		});
	};
	
	that.setupModal = function(doesConcur) {
		$scope.decision_.supervisorConcurred = doesConcur;
		$scope.decision_.forFinalizeDecision = doesConcur;
		if ($scope.decision_.supervisorConcurred) {
			that.supervisorReviewModalText = 'I concur with the Adjudicator\'s decisions';
		} else {
			that.supervisorReviewModalText = 'I do not concur with the Adjudicator\'s decisions'; 
		}
	};
	
	that.doSubmitSupervisorReview = function() {
		that.renderDecisionMessages = [];

		that.saving = true;
		decisionServices.runDecisionChecks($scope.decision_).then(function (decisionStops) {
			$scope.hardStops = decisionStops.data;
			if (decisionStops.data.length > 0) {
				that.resetView();
			} else {
				decisionServices.supervisorReview($scope.decision_).then(function (response) {
					that.saving = false;
					$scope.$emit('broadcastToAll', 'supReviewSaved', {});
					$scope.decision_ = response.data;
					that.loadData(response.data);
					that.addNote();
					$scope.$emit('broadcastToAll', 'confirmModal:close', {});
					that.renderDecisionMessages.push({message: "Successfully saved", type: "success"});
					$rootScope.$broadcast('dyn-tab-removeSelected-mainMenu', "My Cases");
					$scope.$emit('broadcastToAll', 'dyn-tab-remove-mainMenu', $scope.cisCase.uscisNumber + " (Case Review - Supervisory Review) ", {});
					$location.path("/");
				}, function() {
					that.saving = false;
					that.renderDecisionMessages.push({message: response.data.message, type: "error"});
				});
			}
		});
	}

	that.shouldShowI512L = function() {
