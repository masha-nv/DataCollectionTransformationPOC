	const FRTF_NON_APPROVAL_DECISIONS = [
		CASE_DECISION_CODES.ADMINCLOSED,
		CASE_DECISION_CODES.DENIED,
		CASE_DECISION_CODES.WITHDRAWN,
		CASE_DECISION_CODES.TERMINATED
	]

	that.shouldForceSupervisorReviewForFrtfReparoleOnNonApprovals = function() {
		return that.isCaseI131FrtfReparole() 
			&& that.selectedCaseDecision !== null
			&& (FRTF_NON_APPROVAL_DECISIONS.includes(that.selectedCaseDecision.caseDecCd))
			&& (that.isInitialOfficerDecisionMode() || that.isReturnedToOfficerMode());
	}
	
	that.doFinalizeDecisionI131F = () => {
		that.renderDecisionMessages = [];
		
		$scope.decision_.renderDecision = that.selectedCaseDecision.caseDecCd;
		$scope.decision_.decisionReasonCode = that.selectedDecisionReason.decRsnCd;
		$scope.decision_.isCaseDecCompleted = true;
		
		decisionServices.saveOrFinalizeDecision($scope.decision_).then(function (response) {
			that.saving = false;
			let errorMessages = response.data.errorMessages;
			if (errorMessages && errorMessages.length > 0) {
				for (let x = 0 ; x < errorMessages.length ; x++) { 
					that.renderDecisionMessages.push({message: errorMessages[x], type: "error"});
				}
			}				
			else {
				that.addNote();
				that.renderDecisionMessages.push({message: 'Decision successfully saved.', type: "success"});
				that.navigateToCaseDetails();
			}
		}, function(error) {
			that.saving = false;
			that.renderDecisionMessages.push({message: error.data.message, type: "error"});
		});
	}
	
	that.handleCaseDecisionChange = function () {
		if (!that.isCaseDecisionEnabled()) {
			return;
		}
	
		that.selectedDecisionReason = null;
		that.selectedConsulateOffice = null;
		that.selectedApprovalNoticeType = null;
		that.selectedWithdrawnNoticeType = null;
		$scope.decision_.ngsDecisionReasonCode = null;

		// Called when Case Decision dropdown changes
		if (that.selectedCaseDecision == null) {
			$scope.decision_.renderDecision = null;
		} else {
			$scope.hardStops = [];
			$scope.decision_.renderDecision = that.selectedCaseDecision.caseDecCd;
			that.decisionReasonOptions = that.mapDecisionReasonOptions($scope.cisCase.formType, that.selectedCaseDecision);
			decisionServices.runDecisionChecks($scope.decision_).then(function (decisionStops) {
				$scope.hardStops = decisionStops.data;
				if (decisionStops.data.length > 0) {
					that.resetView();
				} else {
					$scope.decision_.renderDecision = that.selectedCaseDecision.caseDecCd;
					that.displayI94();
					that.displayParoleBackdate();
					that.decisionReasonOptions = that.mapDecisionReasonOptions($scope.cisCase.formType, that.selectedCaseDecision);

					if ($scope.decision_.renderDecision === CASE_DECISION_CODES.APPROVED) {
						if (that.isCaseI131FrtfReparole()) {
							that.selectedDecisionReason = that.findDecisionReason(Number(RENDER_DECISION.DECISION_REASON_APPROVED));
							that.handleDecisionReasonChange();
						}
						that.noticeOptionValue = 'select';
							
						//Automatically selects the only approval notice type for CAFRP/CFRP, I-131 HP11 or I-131 DACA approve decisions
						if (that.isCaseI131CAFRP() || that.isCaseI131FrtfReparole() || $scope.isI131HP11() || (that.isCaseI131HP() && 
							$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE || 
							$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE_NO_PROGRAM || 
							$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_INITIAL_PAROLE || 
							$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_US_INITIAL_PAROLE_NO_PROGRAM)) {
							that.selectedApprovalNoticeType = that.mapApprovalNoticeTypeOptions()[0];
							$scope.decision_.ngsDecisionReasonCode = that.selectedApprovalNoticeType.value;
						}
					}

					if ($scope.decision_.renderDecision === CASE_DECISION_CODES.CONDITIONALLY_APPROVE) {
						if($scope.isI131HP11()) { // question 11 
							that.selectedDecisionReason = that.findDecisionReason(Number(RENDER_DECISION.COND_REPAROLE_REQ));
						} else if($scope.isI131HP8B()) { // question 8
							that.selectedDecisionReason = that.findDecisionReason(Number(RENDER_DECISION.COND_PIP_FRTF_REQ));
						}
						else {
                        	that.selectedDecisionReason = that.findDecisionReason(Number(RENDER_DECISION.CONDITIONALLY_APPROVE_FEE_REQUIRED));
						}
                        that.handleDecisionReasonChange();
                    }
                    
					if (that.isCaseI131HP() && ($scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE || 
						$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_INITIAL_PAROLE) && $scope.decision_.renderDecision == CASE_DECISION_CODES.CONTINUE) {
						that.selectedContinueNoticeType = CASE_REVIEW_CONFIG.continueNoticeTypes.REFER_FOR_FURTHER_PAROLE_PROCESSING;
						that.handleContinueNoticeTypeChange();
					}

					if (that.isI131FrtfReParoleContinueDecisionMade()) {
						that.noticeOptionValue = 'none';
					}

					if (that.isCaseI131DACA()) {
						that.updateIfCasePaymentValidationCompleted();
					}
			
					that.handleMissingI94NumberMessage();	
				}
			});
		}
	};

