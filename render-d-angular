			}
			else {
				return caseDecisionCode != CASE_DECISION_CODES.APPROVED;
			}
		}
		else if (that.isValidHR1QuestionCase() && that.addressChangedAfterHR1Fee) {
			return caseDecisionCode != CASE_DECISION_CODES.APPROVED;
		} else {
			return caseDecisionCode != CASE_DECISION_CODES.CONDITIONALLY_APPROVE;
		}
	}
		
	that.mapCaseDecisionOptions = function(formType, permitted_decision_codes) {
		return $scope.refData.decisionCdSubsetData[formType]
			.filter(dec => (permitted_decision_codes.indexOf(dec.caseDecCd.caseDecCd) > -1 && that.displayHR1Decision(dec.caseDecCd.caseDecCd)))
			.map(dec => dec.caseDecCd);
	};
	
	that.mapDecisionReasonOptions = function(formType, decision) {
		let reasonOptions =  $scope.refData
			.decisionReasonSubsetCodes[formType]
			.filter(res =>
				res.decisionReasonType.caseDecCd === decision.caseDecCd
				&& (
					!that.config.reasons.hasOwnProperty(decision.caseDecCd)
					|| that.config.reasons[decision.caseDecCd].indexOf(String(res.decRsnCd)) > -1
				)
			);
		if(decision.caseDecCd === 6 && $scope.cisCase.caseTypeName === "I-131-HP" && reasonOptions != null) {
			reasonOptions = reasonOptions.filter(function (ro) {
				return ro.decRsnCd !== 33;
			});
		}
		if (decision.caseDecCd === 1)  { //Approved
			if(that.isCaseI131HPOAW() || that.isCaseI131DOSLES() || that.isCaseI131UHPReparole()) {
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 2); 
			} else if (that.isCaseI131DACA()) {
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 96 ||res.decRsnCd === 22);
			} else if (that.isCaseI131RPOrRTD()){
				//filter for approval reasons based on whether this is SCOPS or RAIO
				reasonOptions = reasonOptions.filter(res => [785, 786].includes(res.decRsnCd));
			} else {
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 2 ||res.decRsnCd === 500);
			}
		}
		if (decision.caseDecCd === 87)  { //Conditional Approval
		
			if($scope.isI131HP11()) { // question 11 
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 770); 		
			} 
					
			if($scope.isI131HP8B()) { // question 8
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 771); 
			}
			
			else { // default cond approval
				reasonOptions = reasonOptions.filter(res => res.decRsnCd === 758); 
			}
						
		}
		relabelDecisionReasons(reasonOptions);
		return reasonOptions;
	};

