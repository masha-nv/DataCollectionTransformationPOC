	const PAROLE_BACKDATE_CASE_TAGS = [
		55, // CAM Re-Parole
		59, // FWVP Re-Parole
		60, // HFRP Re-Parole
		61, // MeK Re-Parole
		102, // Reparole
		130, // FRTF Re-parole Sep Child
		131, // FRTF Re-parole Sep Parent/LG
		132, // FRTF Re-parole AFM
	];

	//determine if the parole backdate capable ui elements display
	that.displayParoleBackdate = function(){
		if (($scope.isI131HP11() || $scope.isI131HP8B()) && !$scope.decision_.startDate && !$scope.decision_.endDate) {
			$scope.paroleBackdate = true;
			that.paroleValidFrom = new Date();
			return;
		}
		
		if (!$scope.cisCase.caseTags) {
			return;
		} 
		
		$scope.paroleBackdate = false;
		if(that.selectedCaseDecision != null && that.selectedCaseDecision.caseDecCd === 1 && 
			$scope.cisCase.caseTags && angular.isArray($scope.cisCase.caseTags)){

			$scope.cisCase.caseTags.forEach(tag => {
				if(PAROLE_BACKDATE_CASE_TAGS.includes(tag.id)) {
					$scope.paroleBackdate = true;
					
					//default the parole valid from date to today's date if it doesn't already exist
					if(!$scope.decision_.startDate && !$scope.decision_.endDate){
						that.paroleValidFrom = new Date();
					}
				}
			});
		}
	}

	//called when the "Parole Valid From" field value changes for parole backdate cases
	that.paroleValidFromChange = function(){
		let now = new Date();
		let todaysYear = parseInt(now.getFullYear());
		let todaysMonth = parseInt(now.getMonth());
		let todaysDay = parseInt(now.getDate());

		let currentDate = new Date(todaysYear, todaysMonth, todaysDay);

		if(that.paroleValidFrom < currentDate){
			$scope.isParoleBackdateInThePast = true;
		}
		else{
			$scope.isParoleBackdateInThePast = false;
		}

		if(that.paroleValidFrom > currentDate){
			$scope.isParoleDateInTheFuture = true;
		}
		else{
			$scope.isParoleDateInTheFuture = false;
		}

		that.paroleDateChange();
	}

	that.validateDateChange = function() {
		if(that.paroleValidFrom > that.paroleValidTo) {
			that.paroleValidTo = null; 
		}
	}

	//called whenever a change is made to the Parole Valid From field, Parole Duration field,
	//or the Parole Duration unit drop-down in order to calculate the Parole Valid To field
	that.paroleDateChange = function(){
		if(!$scope.paroleBackdate || !($scope.decision_.paroleDurationUnit && $scope.decision_.paroleDuration && that.paroleValidFrom)){
			return;
		}
		
		if($scope.decision_.paroleDurationUnit == "Years"){
			that.paroleValidTo = new Date(that.paroleValidFrom);
			that.paroleValidTo.setFullYear(parseInt(that.paroleValidTo.getFullYear()) + parseInt($scope.decision_.paroleDuration));
		}
		else if($scope.decision_.paroleDurationUnit == "Months"){
			that.paroleValidTo = new Date(that.paroleValidFrom);
			that.paroleValidTo.setMonth(parseInt(that.paroleValidTo.getMonth()) + parseInt($scope.decision_.paroleDuration));
		}
		else if($scope.decision_.paroleDurationUnit == "Days"){
			that.paroleValidTo = new Date(that.paroleValidFrom);
			that.paroleValidTo.setDate(parseInt(that.paroleValidTo.getDate()) + parseInt($scope.decision_.paroleDuration));
		}

		that.paroleValidTo.setDate(parseInt(that.paroleValidTo.getDate()) - 1);
	}

	that.resetView = function() {
		$scope.decision_ = angular.copy($scope.backupDecision);
		that.selectedCaseDecision = null;
	};

	that.handleI131FCaseDecisionChange = function () {
		if (that.selectedCaseDecision && $scope.decision_.renderDecision == that.selectedCaseDecision.caseDecCd) {
			return;
		}
		that.selectedDecisionReason = null;
		if (that.selectedCaseDecision == null) {
			$scope.decision_.renderDecision = null;
		} else {
			$scope.decision_.renderDecision = that.selectedCaseDecision.caseDecCd;
			that.decisionReasonOptions = that.mapDecisionReasonOptions($scope.cisCase.formType, that.selectedCaseDecision);	
			if (that.i131F.isApprovedDecisionMade()) {
				that.noticeOptionValue = 'select';
