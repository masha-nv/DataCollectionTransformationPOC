	that.checkPaymentSuccessForEAD = function() {
		feesService.getPaymentsViewData($scope.cisCase.caseId).then(function(response) {
			let payments = response.data.payments.feePayments.filter(val => val.feeStatus === 'Failed' || val.feeStatus === 'Collected');

			let caseFees = response.data.caseFees.filter(val => val.feeType === 'I-765 EAD Payment');

			if(caseFees.length === 0) {
				that.showEadBanner = false;
				return;
			}

			that.showEadBanner = true;

			if(payments.length === 0){
				that.paymentSuccessForEad = true;
			}
		})
	};

	that.checkPaymentStatusForHR1 = function() {
		feesService.getPaymentsData($scope.cisCase.caseId).then(function(response) {
			let paymentsHR1 = response.data.filter(payment => payment.feeType === 'HR-1 Fee');
			if (paymentsHR1.length > 0) {
				let settledPayments = paymentsHR1.filter(hr1payment => hr1payment.feeStatus === "Settled");

				if (settledPayments.length > 0) {
					that.infoBannerHR1Payment = "paid and settled";
					that.successfulHR1PaymentInfo = true;
				} else {
					that.infoBannerHR1Payment = "paid and failed";
					that.successfulHR1PaymentInfo = false;
				}
			} else {
				that.infoBannerHR1Payment = "not paid";
