		}

		if (that.isCaseI131DACA()) {
			return new Array(DACA_I131_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_DACA_MULTIPLE, 
							 DACA_I131_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_DACA_SINGLE,);
		}

		if (that.isCaseI131PIP()) {
			return getPIPNoticeTypeOptions();
		}
		
		if (that.isCaseI131HPOAW() && that.hasEAD()) {
			return new Array(OAW_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_OAW_REPAROLE_EAD);
		}
		if (that.isCaseI131HPOAW() && !that.hasEAD()){
			return new Array(OAW_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_OAW_REPAROLE_NO_EAD);
		}
		
		if (that.isCaseI131UHPReparole() && that.hasEAD()) {
			return new Array(UHP_REPAROLE_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_UHP_REPAROLE_EAD);
		}

		if (that.isCaseI131UHPReparole()) {
			return new Array(UHP_REPAROLE_CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_UHP_REPAROLE);
		}

		if (that.caseHasFRTFReparoleCaseTag()) {
			return new Array(CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_PAROLE_IN_PLACE);
		}
		
		if (that.caseHasReparoleCaseTag()) {
			return new Array(CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_REPAROLE);
		}

		if (that.caseHasPIPCaseTag()) {
			return new Array(CASE_REVIEW_CONFIG.approvalNoticeTypes.APPROVAL_PAROLE_IN_PLACE);
		}
		
		if (that.isCaseI131CAFRP()) {
			return new Array(CAFRP_CONDUCT_INTERVIEW_CONFIG.approvalNoticeTypes.APPROVAL_CFRP);
		}
		
		if (that.isCaseI131HP()) {
			if ($scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE_NO_PROGRAM || 
				$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_US_INITIAL_PAROLE_NO_PROGRAM) {
				return new Array(CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL);
			}
			else if ($scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE || 
					 $scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_INITIAL_PAROLE) {
				return new Array(CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL_FRTF);
			}
		}

		return 	new Array(
					CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL,
					CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL_AFGAN,
					CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL_AFGAN_IN_PAKISTAN,
					CASE_REVIEW_CONFIG.approvalNoticeTypes.CONDITIONAL_APPROVAL_FRTF
