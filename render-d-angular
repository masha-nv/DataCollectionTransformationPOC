	that.select_config = function() {
		let filingType = $scope.cisCase.caseFilingTypeCode;
		
		if ([FILING_TYPE_HP, FILING_TYPE_HP_ICE].includes(filingType)) {
			const config = ($scope.isI131HP11 || $scope.isI131HPAdvanceParole || $scope.isI131HP10 || $scope.isI131FRTFInsideUSParole) ? I131HP11_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType) : HP_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			if (config) {
				return config;
			} else {
				return CASE_REVIEW_CONFIG;
			}
		} else if (filingType === FILING_TYPE_CAFRP) {
			let taskType = that.isConductInterview() ? 
				TASK_TYPE.CONDUCT_INTERVIEW : $scope.cisCase.userTask.taskType;
					
			const config = CAFRP_TASK_TYPE_TO_CONFIG_MAP.get(taskType);
			if (config) {
				return config;
			} else {
				return CAFRP_CASE_REVIEW_CONFIG;
			}
		} else if (filingType === FILING_TYPE_HP_OAW) {
			return getOawConfig();
		} else if (filingType === FILING_TYPE_I131F) {
			if(this.isCaseDetailsView()){
				return I131F_CASE_DETAILS_CONFIG;
			}
			const config = I131F_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			
			if (config) {
				return config;
			} else {
				return I131F_CASE_DETAILS_CONFIG;
			}
		} else if (filingType === FILING_TYPE_DOS_LES) {
			const config = DOS_LES_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			if (config) {
				return config;
			} else {
				return DOS_LES_CASE_REVIEW_CONFIG;
			}
		} else if (filingType === FILING_TYPE_UHP_REPAROLE) {
			if(this.isCaseDetailsView()){
				return UHP_REPAROLE_CASE_DETAILS_CONFIG;
			}
			const config = UHP_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			if (config) {
				return config;
			} else {
				return UHP_REPAROLE_CASE_REVIEW_CONFIG;
			}
		} else if (filingType === FILING_TYPE_DACA_I131_SWF) {
			const config = DACA_I131_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			if (config) {
				return config;
			} else {
				return DACA_I131_CASE_REVIEW_CONFIG;
			}
		} else if (filingType === CASE_FILING_TYPE_CODES.I131_FRTF_RE_PAROLE) {
			return getFRTFConfig();
		} else if (that.isCaseI131PIP()) {
			const config = I131_PIP_TASK_TYPE_TO_CONFIG_MAP.get($scope.cisCase.userTask.taskType);
			if (config) {
				return config;
			} else {
				return I131_PIP_CASE_REVIEW_CONFIG;
			}
		} else if (CASE_FILING_TYPE_CODES.I131_RP_RTD_FILING_TYPES.includes(filingType)){
			return I131_RP_AND_RTD_CASE_REVIEW_CONFIG;
		}
	};

