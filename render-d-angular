		|| (that.isCaseI131CAFRP() && that.selectedCaseDecision && that.selectedCaseDecision.caseDecCd === 1 && $scope.cisCase.currentCaseLocation !== 'RIH');
	}
	
	that.shouldShowDocumentReviewChecklist = function (){
		return that.isCaseI131CAFRP() && !that.isI131CAFRPApprovedDecisionMade();
	}

	that.isFormValidForCAFRP = function(){
		return that.isFormValid() && 
			that.selectedDecisionReason && 
			(!that.isContinueDecisionSelected() || 
			that.isContinueDecisionSelected() && 
			that.allDocumentReviewCheckboxesMarked());
	}

	that.isSaveDecisionButtonDisabled = function() {
		return !that.isCaseDecisionEnabled() || 
			!that.isFormValidForCAFRP() ||
			(that.isContinueDecisionSelected() && 
			!that.allDocumentReviewCheckboxesMarked());
	}

	that.isContinueDecisionSelected = function() {
		return that.selectedCaseDecision && 
			that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.CONTINUE
	}

	that.allDocumentReviewCheckboxesMarked = function() {
		return $scope.decision_.approvedI130Reviewed &&
			$scope.decision_.approvedI134Reviewed &&
			$scope.decision_.departmentOfStateInvitationReviewed		
	}

	that.setupSaveDecision = function(){
		that.confirmActionModal.action = "Save Decision";
		that.confirmActionModal.uscisNo = $scope.cisCase.uscisNumber;
		that.confirmActionModal.callback = that.saveDecision;
	}

	that.isI131CAFRPContinueDecisionMade = () => that.selectedCaseDecision ? that.isCaseI131CAFRP() && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.CONTINUE : false;
	that.isI131CAFRPContinueNoticeTypesVisible = () => that.isI131CAFRPContinueDecisionMade() && that.noticeOptionValue == 'select';

	that.isI131HPContinueNoticeTypesVisible = () => that.isI131HPContinueDecisionMade() && that.noticeOptionValue == 'select';
	that.isI131HPContinueDecisionMade = () => that.selectedCaseDecision ? (($scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OUTSIDE_US_INITIAL_PAROLE || 
				$scope.cisCase.benefitType == BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_INITIAL_PAROLE) && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.CONTINUE) : false;

	that.isI131CAFRPClosedDecisionMade = () => that.selectedCaseDecision ? that.isCaseI131CAFRP() && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.ADMINCLOSED: false;

	that.isI131CAFRPApprovedDecisionMade = function(){
		if(that.selectedCaseDecision){
			return (that.isCaseI131CAFRP() && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.APPROVED);
		}
		return false;
	}

	that.isI131CAFRPWithdrawnDecisionMade = function(){
		if(that.selectedCaseDecision){
			return (that.isCaseI131CAFRP() && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.WITHDRAWN);
		}
		return false;
	}

	that.isI131CAFRPApprovalNoticeTypesVisible = function(){
		return (that.isI131CAFRPApprovedDecisionMade() && that.noticeOptionValue == 'select');
	}

	that.isI131CAFRPWithdrawnNoticeTypesVisible = function(){
		return (that.isI131CAFRPWithdrawnDecisionMade() && that.noticeOptionValue == 'select');
	}

	that.isI131DACAApprovalNoticeTypesVisible = function(){
		return (that.isI131DACAApprovalDecisionMade() && that.noticeOptionValue == 'select');
	}

	that.isPIPApprovalNoticeTypesVisible = function(){
		return (that.isPIPApprovalDecisionMade() && that.noticeOptionValue == 'select');
	}

	that.shouldShowSaveDraft = function() {
		return (that.taskPillsEnabled || that.i131HPBatchDecisionBeta) && 
			that.concurrentDecisions.length > 1 && 
			$scope.cisCase.currentCaseLocation === 'RIH' && 
			!that.isCaseI131CAFRP();
	}

	that.decisionTaskAssignedToUser = function(dec) {
		return dec.userTaskOwnerId === parseInt(security.getSecurityData().partyId);
	}

	that.getSaveDraftLanguage = function() {
		let pendingDecisions = getPendingConcurrentDecisions();
		if (pendingDecisions.length === 0) {
			return 'Save Draft and Proceed to Finalize Decision';
		} else {
			return 'Save Draft and View Next Case';
		}
	}

	function getPendingConcurrentDecisions() {
		return that.concurrentDecisions.filter((dec) => dec.caseId !== $scope.cisCase.caseId && dec.caseDecisionStatus == null);
	}

	function relabelDecisionReasons(decisionReasons) {
		let rescheduleForReinterviewDecisionReason = decisionReasons.find((reason)=>{
			return reason.decRsnCd === 136;
		});
		
		if(rescheduleForReinterviewDecisionReason && that.isCaseI131CAFRP() && $scope.cisCase.userTask.taskType === TASK_TYPE.CONDUCT_INTERVIEW){
			rescheduleForReinterviewDecisionReason.decRsnDesc = 'Reschedule For Re-Interview';
		}
	}

	that.getRequestSupervisoryReviewLabel = () => that.isCaseI131CAFRP() ? 'Finalize Decision' : 'Route to Supervisory Review';

	that.checkI131HPFPForOpenReferral = function (){
		if(that.isCaseI131HP()){
			decisionServices.checkOtherFamilyPackCasesWithOpenTecsHits($scope.cisCase.caseId).then((response) => {
				that.showI131HPFPWarningMessage = response.data;
			});
		}
	}

	that.setClassOfAdmission = () => {
		that.classOfAdmissionOptions = ["MIL", "CP"];
		if (PIP_BENEFIT_TYPES_FOR_COA_MIL.has($scope.cisCase.benefitType)) {
			that.selectedClassOfAdmission = "MIL";
			$scope.decision_.classOfAdmission = "MIL";
		} else if (PIP_BENEFIT_TYPES_FOR_COA_CP.has($scope.cisCase.benefitType)) {
			that.selectedClassOfAdmission = "CP";
			$scope.decision_.classOfAdmission = "CP";
		}
	}

	that.setParoleDuration = () => {
		if ($scope.cisCase.frtf) {
			$scope.decision_.paroleDuration = 36;
			$scope.decision_.paroleDurationUnit = 'Months';
		} else if (that.isCaseI131PIP()) {
			$scope.decision_.paroleDuration = 1;
			$scope.decision_.paroleDurationUnit = 'Years';
		}
	}

	that.navigateToRiskAndFraud = function() {
		navigateTo($scope.cisCase.uscisNumber, 'Risk and Fraud', 'RiskandFraud_collapsible');
	}

	that.isReInterviewSelected = function(){
		return that.selectedDecisionReason && that.selectedDecisionReason.decRsnCd === 136; // "Reschedule For Re-Interview"
	}

	function navigateTo(receiptNumber, linkTitle, collapsibleId) {
		if($rootScope.isTaskResolutionContext() && $stateParams.workTypeCode) {
			if($stateParams.receiptNumber === receiptNumber) {
				$rootScope.$broadcast('activateLink', {linkTitle: linkTitle});
			} else {
				$location.path('/taskResolution/' + receiptNumber + '/' + $stateParams.workTypeCode + "/")
					.search({link: linkTitle});
			}
		} else {
			$rootScope.$broadcast(collapsibleId + ':show', true);
			let el = $("#" + collapsibleId);
			if(el) {
				el[0].scrollIntoView(true)
			}
		}
		$scope.$apply();
	}

	that.showAdjCloseOutModal = function () {
		$scope.isShowingNexgenModal = true;
	}

	that.toggleNexgenModal = (isShowing) => {
		$scope.isShowingNexgenModal = isShowing;
	}

	that.is131ConditionallyApproved = function() {
		return that.selectedCaseDecision && that.selectedCaseDecision.caseDecCd === CASE_DECISION_CODES.CONDITIONALLY_APPROVE; 
	}

	that.getConditionallyApproveButtonLabel = () => that.is131ConditionallyApproved() ? 'Conditionally Approve' : 'Finalize Decision';

	// Final IDENT Checks Implementation
	formConfigService.getFormConfigValueByCaseFilingType($scope.cisCase.formType, $scope.cisCase.caseFilingTypeCode, "jitIdentConfigByCaseFilingType").then(result => {
		if(result) {
			that.isAdhocJITIDENTEnabled = result.isAdhocEnabled || (
				result.adhocForCaseFilingType != null &&
				result.adhocForCaseFilingType.includes(Number($scope.cisCase.caseFilingTypeCode))
			);
			that.isJITIDENTCheckEnabled = result.isJITIDENTCheckEnabled;
			that.isJITEnabledDecisionCodes = result.validCaseDecisions;
		}
	});

	that.shouldShowRunJitChecksButton = function() {
		return that.selectedCaseDecision &&
			that.isAdhocJITIDENTEnabled &&
			that.isJITIDENTCheckEnabled &&
			that.isJITEnabledDecisionCodes  != null &&
			that.isJITEnabledDecisionCodes.includes(that.selectedCaseDecision.caseDecCd)
	}
}
