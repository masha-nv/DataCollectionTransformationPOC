	that.i131F.mapProvisionalDenialReasonsBooleanToResponseCd = () => {
		that.i131F.provisionalDenialReasonList = that.i131F.provisionalDenialReasonList.map(function(question) {
			if ( question.binaryYesNo === true ) {
				question.responseCd = "Y";
			}
			else {
				question.responseCd = "N";
			}
			
			return question;
		});
		
	}
	
	that.i131F.mapProvisionalDenialReasonsResponseCdToBoolean = () => {
		if ( that.i131F.provisionalDenialReasonList != null && that.i131F.provisionalDenialReasonList != undefined ) {
			that.i131F.provisionalDenialReasonList = that.i131F.provisionalDenialReasonList.map(function(question) {
				if ( question.responseCd === "Y" ) {
					question.binaryYesNo = true;
				}
				else {
					question.binaryYesNo = false;
				}
				
				return question;
			});
		}
	}
	
	that.i131F.saveProvisionalDecision = function() {
		if ( !that.i131F.isProvisionalApproval || "rfe" === that.i131F.isProvisionalApproval) {
			that.i131F.mapProvisionalDenialReasonsBooleanToResponseCd();

			decisionServices.saveProvisionalReasons($scope.cisCase.uscisNumber, that.i131F.provisionalDenialReasonList, "rfe" !== that.i131F.isProvisionalApproval).then(function(response) {
				that.i131F.provisionalDenialReasonList = response.data;
				that.i131F.mapProvisionalDenialReasonsResponseCdToBoolean();
				that.navigateToCaseDetails();
			});
		}
		else {
			that.i131F.persistProvisionalDecisionFlag(true);
		}
	}
	
