	$scope.isI131FRTFInsideUSParole = function(){
		let hasPIPFRTFCaseTag = false;
		if($scope.cisCase.caseTags && angular.isArray($scope.cisCase.caseTags)){
			$scope.cisCase.caseTags.forEach(tag => {
				if(tag.shortDescription && tag.shortDescription.includes('PIP FRTF')){
					hasPIPFRTFCaseTag = true;
				}
			});
		}
		return $scope.cisCase.caseFilingTypeCode === FILING_TYPE_HP && ($scope.cisCase.benefitType === 150 || $scope.cisCase.benefitType === 151) && hasPIPFRTFCaseTag;
	}
	
	
	const callGetPassportData = (beneficiaryId)=>{
		if(beneficiaryId){
			let isIncludeInactiveData = $scope.cisCase.formType === 'I-131' && $scope.cisCase.formRevisionDate >= '2024-06-17';
			const getPassportData = isIncludeInactiveData ? biographicServices.getNonHistoricalPassportData($scope.cisCase.caseId, beneficiaryId)
					: biographicServices.getPassportData($scope.cisCase.caseId, beneficiaryId);
			return getPassportData;
		}
	}

	$scope.getPassportData = function() {

		let idForPassport;
		if($scope.is1f()){
			idForPassport = $scope.cisCase.beneficiaryId;
		}
		else{
			idForPassport = $scope.cisCase.personId;
		}

		callGetPassportData(idForPassport).then( function(response) {
			for(let i = 0; i < response.data.length; i++) {
				if(response.data[i].docPrimaryHolder == true){
					$scope.decision_.passportNumber = response.data[i].docNumber;
				}
			}
		},
		function() {
			if (response.status == 404) {
				$scope.errorHandler.push({ 'text': "Service unavailable please contact help desk", 'type': 'error', 'id': '404' });
				return;
			}
			$scope.errorHandler.addError(response.data.message, 'accountBiographicsErrorMsgs');
		});
	}

	that.loadConcurrentCaseDecs = function() {
		decisionServices.getConcurrentCaseDecisions($scope.cisCase.caseId, $scope.cisCase.personId).then(function(response) {
			that.concurrentDecisions = response.data;
			that.concurrentDecisions.forEach((dec) => dec.sendToSupervisorReview = dec.supervisorReviewCode === 'Y');
			that.finalizeAllMode = that.finalizeAllMode || !that.isReadOnlyMode() && !that.isSupervisorActionsVisible() && that.shouldShowSaveDraft() && !$location.search().edit && that.concurrentDecisions.filter((dec) => dec.caseDecisionStatus == null).length === 0;
		});
