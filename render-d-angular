		decisionServices.getData($scope.cisCase.caseId, $scope.cisCase.personId).then(function(response) {
			$scope.decision_ = response.data;
			$scope.decision_.issuedDate = $scope.decision_.issuedDate ? new Date($scope.decision_.issuedDate) : null;
			$scope.decision_.validUntilDate = $scope.decision_.validUntilDate ? new Date($scope.decision_.validUntilDate) : null;
			$scope.decision_.printingOption = $scope.decision_.printingOption ? $scope.decision_.printingOption.toString() : null;
			$scope.decision_.userTaskId = $stateParams.taskId;
			
