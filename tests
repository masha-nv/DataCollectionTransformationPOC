        validityPeriodType: -1,
        startValidity: '',
        endValidity: '',
        isValid: false,
      },
      admittance: '',
    };
    const onUpdate = (data: RDUpdate) => {
      latestData = data;
    };
    render(
      <Provider store={store}>
        <I131RpRtdRenderDecision
          cisCase={{ ...CISCASE_FROM_STORE, caseFilingTypeCode: '562' }}
