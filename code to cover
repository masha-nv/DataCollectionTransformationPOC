		})
		.then($scope.cisCase.caseFilingTypeCode === CASE_FILING_TYPE_CODES.I131_CFRP_FILING ? i131CaseReviewService.getUIHeaderForCAFRP : 
			$scope.cisCase.caseFilingTypeCode === CASE_FILING_TYPE_CODES.I131_DACA_SWF ? i131CaseReviewService.getUIHeaderForDACA : $scope.isI131PIP() ? 
			i131CaseReviewService.getUIHeaderForPIP : $scope.isI131RPRTD() ? i131CaseReviewService.getUIHeaderForRPRTD : i131CaseReviewService.getUIHeader)
		.then(function(result) {
			if(!$scope.isI131RPRTD()){
				orderSection(result.data);
			}
			mergeNavData(result.data);
			//
			$scope.navigationSections = result.data.links;
			let idForNavigation = $scope.navigationSections[0].links[0];
			let linkForNavigation = $location.search().link;
			if (linkForNavigation) {
				if (linkForNavigation === 'renderDecision') {
					linkForNavigation = I131_HP_CASE_REVIEW_UI_HEADER.RENDER_DECISION;
				}
				let matchingLinks = $scope.navigationSections.flatMap((section) => section.links).filter((link) => link.id === linkForNavigation);
				if (matchingLinks.length > 0) {
					idForNavigation = matchingLinks[0];
				}
			}
	  		$scope.navigation = { activeLink: idForNavigation };
		});
	}
	
	function orderSection(section) {	
		var caseDataLinks = section.links[1].links;
		const biometricsAndAppointments = caseDataLinks.splice(caseDataLinks.length-2, 2);
		caseDataLinks.splice.apply(caseDataLinks, [2, 0].concat(biometricsAndAppointments));
	}
		
	function mergeNavData(section) {		
		if(navData[section.id]) {				
			section = angular.extend(section, navData[section.id]);	
		}

		section.visible = true;

		if(!section.links) {
			return;
		}

		for(var i = 0; i < section.links.length; i++) {
			mergeNavData(section.links[i]);
		}
		
		if($scope.is1f()){
			callGetPassportData($scope.cisCase.beneficiaryId).then( function(response) {
				$scope.cisCase.beneficiaryPassportNumber = response.data});
		}
		
		callGetPassportData($scope.cisCase.personId).then( function(response) {
			$scope.cisCase.passportNumber = response.data});
			
		$scope.appPetName = {"lastName" : $scope.cisCase.lastName, "firstName" : $scope.cisCase.firstName, "middleName" : $scope.cisCase.middleName}
		$scope.beneficiaryPlaceOfBirth = $scope.cisCase.beneficiaryCountryOfBirth ? UtilHelper.lookUp($rootScope.refData.birthCountryCodes,$scope.cisCase.beneficiaryCountryOfBirth,"birthCountryCode","birthCountryName") : '';
		$scope.petOrAppPlaceOfBirth = $scope.cisCase.countryOfBirth  ? UtilHelper.lookUp($rootScope.refData.birthCountryCodes,$scope.cisCase.countryOfBirth,"birthCountryCode","birthCountryName") : '';
	}
	
	const callGetPassportData = (beneficiaryId)=>{
		let isIncludeInactiveData = $scope.cisCase.formType === 'I-131' && $scope.cisCase.formRevisionDate >= '2024-06-17';
		const getPassportData = isIncludeInactiveData ? biographicServices.getNonHistoricalPassportData($scope.cisCase.caseId, beneficiaryId)
				: biographicServices.getPassportData($scope.cisCase.caseId, beneficiaryId);
		return getPassportData;
	}
			
	$scope.updateReviewed = function(id, completed) {
		i485CaseReviewService.toggleReviewed($scope.cisCase.caseId, id, completed)
		.then(function() {
			$scope.navigation.activeLink.completed = completed;
		})
	}
	
	
	$scope.cisCase.getSponsorData = function(sponsorId){
		
		if($scope.cisCase.sponsorIds.length == 0){
			return;
		}
		
		// retrieve sponsor data based on Id 
		callGetPassportData(sponsorId).then(function(response) {
			that.sponsorPassportNumber = response.data;
		});
			
		alienNumberServices.getAlienNumbersWithHistory(sponsorId, $scope.cisCase.caseId).then(function(response) {
			that.sponsorAlienNumber = response.data.primaryAlienNumber;
		});
		
		naturalizationService.getBiographics($stateParams.receiptNumber,sponsorId).then(function(response){
			that.sponsorPlaceOfBirth = response.data.cobs.latest.item.countryName;
			that.sponsorGender = response.data.genders.latest.item.description;
		});
		
		dobServices.getDataList($scope.cisCase.caseId, sponsorId, false).then(function(response) {
				that.sponsorDob = response.data[0].birthDate;
				});
					
		nameServices.getCasePersonNames($scope.cisCase.caseId, sponsorId)
    		.then(function(response) {
			that.sponsorName = {"lastName" : response.data.primaryLastName, "firstName" : response.data.primaryFirstName, "middleName" : response.data.primaryMiddleName};	
    		})

		SponsorService.getCitizenshipInfo(sponsorId).then(function(response) {
			that.sponsorCOC = response.data.countriesOfCitizenship[0];
			if(response.data.countriesOfCitizenship.length > 1){
				that.sponsorACOC = response.data.countriesOfCitizenship.filter(coc => coc !== that.sponsorCOC);
			}
		});	

		if($scope.shouldUseMultipleCobs && ($scope.isI131HP || $scope.isI131CFRP)) {
			biographicServices.getAllPersonCountriesOfBirthDTO(sponsorId).then(function(response) {
				that.sponsorPrimaryCob = response.data.personCountryOfBirthDTOList.filter(cob => cob.primaryIndicator == true);
				that.sponsorOtherCobs = response.data.personCountryOfBirthDTOList.filter(cob => cob.primaryIndicator == false);
			});	
		}
	}
	
	formConfigService.getFormConfigValue($scope.cisCase.formType, 'usePersonCountryOfBirthEnabled').then(result => {
		$scope.shouldUseMultipleCobs = result;
	});

	const OTHER_PETITIONED_HP_TYPES = new Set();
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_ADVANCE_PAROLE);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_INITIAL_PAROLE);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_OUTSIDE_US_INITIAL_PAROLE_NO_PROGRAM);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_INSIDE_US_INITIAL_PAROLE);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_INSIDE_US_INITIAL_PAROLE_NO_PROGRAM);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_INSIDE_US_NEW_PERIOD_OF_PAROLE);
	OTHER_PETITIONED_HP_TYPES.add(BENEFIT_TYPE_DESCRIPTIONS.OTHER_INSIDE_US_NEW_PERIOD_OF_PAROLE_NO_PROGRAM);
	
	$scope.is1f = function() {
		return OTHER_PETITIONED_HP_TYPES.has($scope.cisCase.benefitType);
	}
	
	$scope.petOrBenHeader = function() {
		return $scope.is1f() ? "Petitioner Summary" : "Applicant Summary";
	}
	
	$scope.i131applicationType = '';
	$scope.i131Persons = [];
	$scope.sponsorSelected = -1;
	$scope.load131Person = function(){
		if([24,146,148,150,152,154,156].includes($scope.cisCase.benefitType)){
			$scope.i131applicationType ='1E';
			$scope.i131Persons.push({
				role: "Applicant",
				id: $scope.cisCase.personId
			})
		}
		if([25,147,149,151,153,155,157].includes($scope.cisCase.benefitType)){
			$scope.i131applicationType = '1F';
			$scope.i131Persons.push({
				role: "Beneficiary",
				id: $scope.cisCase.beneficiaryId
			},
			{
				role: "Petitioner",
				id: $scope.cisCase.petitionerId
			})
		}
		if($scope.i131Persons.length !== 0){
			that.currentPerson = $scope.i131Persons[0].id;
			$scope.currentPerson = that.currentPerson
		}
	}
	$scope.load131Person();
	
	$scope.changeCurrentTab = function(person) {
		$scope.currentPerson = person;
		$scope.sponsorSelected = $scope.cisCase.sponsorIds.indexOf(person);
	}

	that.getAnalysisQuestionData = function() {
		i131CaseReviewService.getAnalysisUIHeader().then(function(response) {
			response.data.links.forEach(function(link) {
                worksheetStatusService.getUIHeaderQuestionsByUIHeaderCodeAndCaseFilingType(
                        $scope.cisCase.caseId, link.id, $scope.cisCase.caseFilingTypeCode).then(function(response) {
                    link.childQuestions = response.data;
                    
                    
                    // swap military and other reason to avoid recreating a whole new view for PIP
                    if (response.data[0].headerId === I131_HP_CASE_REVIEW_UI_HEADER.PAROLE_REQUEST && $scope.isI131PIP()) {
						let questionToSwap = response.data[1].childQuestions[6];
						response.data[1].childQuestions[6] = response.data[1].childQuestions[5];
						response.data[1].childQuestions[5] = questionToSwap;
					}
                    
					if(response.data[1].headerId == 563 && $scope.cisCase.caseFilingTypeCode === CASE_FILING_TYPE_CODES.I131_OAW_REPAROLE){
							response.data[1].childQuestions[3].yes = true;
							response.data[1].childQuestions[3].responseCd = YES_RESPONSE;

							response.data[1].childQuestions[5].yes = true;
							response.data[1].childQuestions[5].responseCd = YES_RESPONSE;
							response.data[1].childQuestions[5].responseText = 'OAW Re-Parole';
					}
					if (response.data[0].headerId === I131_HP_CASE_REVIEW_UI_HEADER.PAROLE_REQUEST) {
						that.isReasonParoleRequestedAnswered = that.isAnsweredReasonParoleRequested(response.data);
					}
				});
			});
			that.links = response.data.links;
			that.analysisSections = response.data.links.reduce(function(map, obj) {
				map[obj.id] = obj;
				return map;
			}, {});
		});
	}
	
	that.isAnsweredReasonParoleRequested = function(paroleRequestQuestions) {
		for (let i = 0; i < paroleRequestQuestions.length; i++) {
			if (paroleRequestQuestions[i].subsectionCodeId === I131_HP_CASE_REVIEW_SUB_SECTION_CODE.REASON_PAROLE_REQUESTED) {
				for (let j = 0; j < paroleRequestQuestions[i].childQuestions.length; j++) {
					if (paroleRequestQuestions[i].childQuestions[j].responseCd) {
						return true;
					}
				}
			}
		}
		return false;
	}

	that.submitAnalysisQuestions = function(valid) {
		if(!valid) {
			return;
		}
		that.analysisSections[I131_HP_CASE_REVIEW_UI_HEADER.PAROLE_REQUEST].childQuestions[0].childQuestions.forEach(function(question) {
			if (question.subsectionCode.keyId === that.paroleRequestedBy) {
				question.responseCd = YES_RESPONSE;
			} else {
				question.responseCd = null;
			}
		});
		let analysisOfParoleSection = that.analysisSections[I131_HP_CASE_REVIEW_UI_HEADER.ANALYSIS_OF_PAROLE_REASON];
		if (analysisOfParoleSection.childQuestions[0].responseCd === 'N' && analysisOfParoleSection.childQuestions[1].responseCd === 'N') {
			clearAnswers(that.analysisSections[I131_HP_CASE_REVIEW_UI_HEADER.THE_EXCERCISE_OF_DISCRETION].childQuestions)
		}
		that.links.forEach(function(link) {
			clearInvalidAnswersByDependencies(link);
		})
		
		worksheetStatusService.saveUIHeaderQuestionsByIdAndTaskIdAndCaseFilingType($scope.cisCase.caseId, I131_HP_CASE_REVIEW_UI_HEADER.ANALYSIS,
			$scope.cisCase.userTask.id, that.links, $scope.cisCase.caseFilingTypeCode).then(function() {
			let id = 'alertSection' + that.messages.length;
			that.messages.push({type: 'success', text: 'Successfully saved the Analysis information', id: id})
			$timeout(function(){
				focusHelper.setFocusToElement(id);
			});
		});
	}
	
	function clearInvalidAnswersByDependencies(question) {
		question.childQuestions.forEach(function(subquestion) {
			if (subquestion.subsectionCode.showIfParentResponseIs && question.responseCd !== subquestion.subsectionCode.showIfParentResponseIs) {
				clearAnswers([subquestion]);
			} else {
				clearInvalidAnswersByDependencies(subquestion);
			}
		});
	}
	
	function clearAnswers(questions) {
		questions.forEach(function(question) {
			question.responseCd = null;
			question.responseText = null;
			question.yes = false;
			clearAnswers(question.childQuestions);
		});
	}
	
	that.updateCheckbox = function(option) {
		if (option.yes) {
			option.responseCd = null;
		} else {
			option.responseCd = YES_RESPONSE;
		}
		that.isReasonParoleRequestedAnswered = that.isAnsweredReasonParoleRequested(that.analysisSections[I131_HP_CASE_REVIEW_UI_HEADER.PAROLE_REQUEST].childQuestions);
	}

	$scope.formatDate = function(date) {
		var yyyy = date.substring(0, 4);
		var mm = date.substring(5, 7);
		var dd = date.substring(8, 10);
		var formattedDate = mm + '/' + dd + '/' + yyyy
		return formattedDate
	}

	$scope.getCountryName = function(countryCode) {
		var countryName = "";
        if(countryCode === null || countryCode === undefined) {
        	return 'UNKNOWN COUNTRY';
        }
        angular.forEach($scope.refData.countryCodes, function (country, index) {
            if (country.countryCode === countryCode) {
                countryName = country.countryName;
                return;
            }
        })
        return countryName.toUpperCase();
    }

    that.isI131FRTFReParoleCase = () => {
        return $scope.cisCase.caseFilingTypeCode === CASE_FILING_TYPE_CODES.I131_FRTF_RE_PAROLE;
    }

    that.setDefaultForI131FRTFReParoleAnalysisOfParoleReasonJustification = function(analysisOfParoleReasonQuestion) {
        const analysisOfParoleReasonJustificationQuestion = that.analysisSections[I131_HP_CASE_REVIEW_UI_HEADER.ANALYSIS_OF_PAROLE_REASON].childQuestions
            .find(childQuestion => childQuestion.subsectionCodeId === I131_HP_CASE_REVIEW_SUB_SECTION_CODE.URGENT_HUMANITARIAN_OR_PUBLIC_BENEFIT_JUSTIFICATION_REASON);
        if (!that.isI131FRTFReParoleCase() || analysisOfParoleReasonQuestion.subsectionCodeId !== I131_HP_CASE_REVIEW_SUB_SECTION_CODE.URGENT_HUMANITARIAN_OR_PUBLIC_BENEFIT
            || !analysisOfParoleReasonJustificationQuestion) {
            return;
        }

        if (analysisOfParoleReasonQuestion.responseCd === YES_RESPONSE && (!analysisOfParoleReasonJustificationQuestion.responseText
            || analysisOfParoleReasonJustificationQuestion.responseText === '')) {
            analysisOfParoleReasonJustificationQuestion.responseText = DEFAULT_I131_FRTF_URGENT_HUMANITARIAN_OR_PUBLIC_BENEFIT_JUSTIFICATION_TEXT;
        } else if (analysisOfParoleReasonQuestion.responseCd !== YES_RESPONSE && analysisOfParoleReasonJustificationQuestion.responseText === DEFAULT_I131_FRTF_URGENT_HUMANITARIAN_OR_PUBLIC_BENEFIT_JUSTIFICATION_TEXT) {
            analysisOfParoleReasonJustificationQuestion.responseText = '';
        }
    }

};
