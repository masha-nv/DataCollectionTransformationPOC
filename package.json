{
  "name": "uscis",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "e2e": "env-cmd -f .cypress.env nx run-many --all --target=e2e",
    "e2e:watch": "env-cmd -f .cypress.env nx run beacon-e2e:e2e --watch",
    "e2e:ci": "env-cmd -f .cypress.env nx run beacon-e2e:e2e --headless --no-cache",
    "storybook": "nx run beacon:storybook --host=0.0.0.0",
    "build-storybook": "nx run beacon:build-storybook",
    "format:ci": "nx format:check --base=origin/ci-pipeline",
    "format": "nx format:write --base=origin/ci-pipeline",
    "test": "nx run beacon:test --watch",
    "test:ci": "nx run beacon:typecheck && nx run beacon:test --codeCoverage --no-cache --ci",
    "test:coverage": "nx run beacon:test --codeCoverage --no-cache --ci",
    "typecheck": "nx run beacon:typecheck",
    "lint": "nx run beacon:lint --fix",
    "lint:ci": "nx run beacon:lint",
    "build": "nx run --verbose beacon:build --verbose",
    "beacon:publish": "npm publish",
    "prepush-check": "npm run format && npm run lint && npm run test:ci && npm run e2e:ci",
    "help": "nx help"
  },
  "private": true,
  "dependencies": {
    "@elis/elis-focus-trap-react": "2.0.27",
    "@popperjs/core": "2.9.0",
    "@react-hook/debounce": "3.0.0",
    "axios": "0.21.1",
    "classnames": "2.3.1",
    "core-js": "3.6.5",
    "document-register-element": "1.13.1",
    "moment": "2.29.4",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-hook-form": "7.3.5",
    "react-innertext": "1.1.5",
    "react-modal": "npm:react-modal-copy@3.12.1",
    "react-popper": "2.2.4",
    "react-rte": "0.16.4",
    "tslib": "2.3.0",
    "use-callback-ref": "1.2.5",
    "use-onclickoutside": "0.3.1"
  },
  "devDependencies": {
    "@babel/core": "7.9.6",
    "@babel/preset-env": "7.9.6",
    "@babel/preset-react": "7.9.4",
    "@babel/preset-typescript": "7.9.0",
    "@elis/uscis-react-datatable": "0.1.16",
