    "@storybook/addon-knobs": "~6.3.0",
    "@storybook/preset-scss": "1.0.3",
    "@storybook/react": "6.3.6",
    "@svgr/webpack": "5.4.0",
    "@testing-library/cypress": "7.0.6",
