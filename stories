const generateStory = (
  mswHandlers: RestHandler<MockedRequest<DefaultBodyType>>[],
  cisCase: ICISCase | null,
  props?: Partial<ICaseFlagsProps>,
  userPermissions?: UserPermissions
) => {
  const Component: Story<ICaseFlagsProps> = (args: ICaseFlagsProps) => {
    useEffect(() => {
      STORE.dispatch(setCISCase(cisCase));
      STORE.dispatch(resetSecurity());
      STORE.dispatch(
        initSecurity(
          MOCK_USER_SECURITY.details,
          MOCK_USER_SECURITY.supervisors,
          MOCK_USER_SECURITY.caseLifeCyclePermissions,
          [
            ...MOCK_USER_SECURITY.skills,
            SkillCodes.REMOVE_FINAL_HOLD
          ],
          {
            ...MOCK_USER_SECURITY.permissions,
            usersRole: 'ENT-SG-ELIS-CaseAccess6',
            userPermissions: userPermissions ?? {},
          }
        )
      );
    });
    return (
      <AngularJSScopeContext.Provider value={mockScope}>
        <Provider store={STORE}>
          <ElisContainer>
            <CaseFlags {...args} />
          </ElisContainer>
        </Provider>
      </AngularJSScopeContext.Provider>
    );
  };

  Component.args = {
    id: 'case-flags-component',
    receiptNum: cisCase === null ? '' : 'IOE111111113',
    ...props,
  };

  Component.parameters = {
    msw: {
      handlers: mswHandlers,
    },
  };

  return Component;
};
